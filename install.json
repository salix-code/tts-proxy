{
  "version": "1.0",
  "description": "tts-proxy 安装规则（默认全自动；仅在升级/替换/选源时询问）",
  "rules": [
    {
      "type": "ensure_uv",
      "name": "检查 uv（缺失或过旧才询问安装/升级）",
      "min_version": "0.4.0",
      "auto_install": true,
      "install_hint": {
        "intro": "uv 不可用。可手动执行：",
        "commands": [
          { "label": "Windows",     "cmd": "powershell -ExecutionPolicy ByPass -c \"irm https://astral.sh/uv/install.ps1 | iex\"" },
          { "label": "macOS/Linux", "cmd": "curl -LsSf https://astral.sh/uv/install.sh | sh" },
          { "label": "已安装-自升级", "cmd": "uv self update" }
        ],
        "docs": "https://docs.astral.sh/uv/getting-started/installation/"
      }
    },
    {
      "type": "check_cuda",
      "name": "检查 CUDA（要求 > 12.0）",
      "skip_os": ["mac"],
      "fatal": true,
      "min_version": "12.0",
      "install_hint": {
        "intro": "未检测到可用的 CUDA（需要 nvcc 或 nvidia-smi 报告 > 12.0）：",
        "commands": [
          { "label": "Windows", "cmd": "下载安装: https://developer.nvidia.com/cuda-downloads" },
          { "label": "Ubuntu",  "cmd": "sudo apt install nvidia-cuda-toolkit" }
        ],
        "docs": "https://docs.nvidia.com/cuda/cuda-installation-guide/"
      }
    },
    {
      "type": "create_uv_venv",
      "name": "创建 Python 3.11 venv（.venv）",
      "python": "3.11",
      "dir": ".venv",
      "install_hint": {
        "intro": "创建虚拟环境失败。可手动执行：",
        "commands": [
          { "label": "手动创建",        "cmd": "uv venv --python 3.11 .venv" },
          { "label": "安装 Python 3.11", "cmd": "uv python install 3.11" }
        ],
        "docs": "https://docs.astral.sh/uv/pip/environments/"
      }
    },
    {
      "type": "install_uv_package",
      "name": "安装 PyTorch (>= 2.5, CUDA 12.1)",
      "package": "torch",
      "import_as": ["torch", "torchaudio"],
      "venv_dir": ".venv",
      "min_version": "2.5.0",
      "install_args": [
        "--index-url", "https://download.pytorch.org/whl/cu121",
        "torchaudio"
      ],
      "spec": "torch>=2.5",
      "install_hint": {
        "intro": "PyTorch 安装失败。按 CUDA 版本手动选择：",
        "commands": [
          { "label": "CUDA 12.1", "cmd": "uv pip install --python .venv/Scripts/python.exe torch>=2.5 torchaudio --index-url https://download.pytorch.org/whl/cu121" },
          { "label": "CUDA 11.8", "cmd": "uv pip install --python .venv/Scripts/python.exe torch>=2.5 torchaudio --index-url https://download.pytorch.org/whl/cu118" },
          { "label": "CPU",       "cmd": "uv pip install --python .venv/Scripts/python.exe torch>=2.5 torchaudio" }
        ],
        "docs": "https://pytorch.org/get-started/locally/"
      }
    },
    {
      "type": "install_uv_package",
      "name": "安装 voxcpm",
      "package": "voxcpm",
      "import_as": ["torch", "torchaudio", "voxcpm"],
      "venv_dir": ".venv",
      "spec": "voxcpm",
      "install_hint": {
        "intro": "voxcpm 安装失败。可手动执行：",
        "commands": [
          { "label": "Windows", "cmd": "uv pip install --python .venv/Scripts/python.exe voxcpm" },
          { "label": "*nix",    "cmd": "uv pip install --python .venv/bin/python voxcpm" }
        ],
        "docs": "https://pypi.org/project/voxcpm/"
      }
    },
    {
      "type": "install_uv_package",
      "name": "安装 huggingface_hub[cli]",
      "package": "huggingface_hub[cli]",
      "import_as": ["huggingface_hub"],
      "venv_dir": ".venv",
      "spec": "huggingface_hub[cli]",
      "install_hint": {
        "intro": "huggingface_hub[cli] 安装失败。可手动执行：",
        "commands": [
          { "label": "Windows", "cmd": "uv pip install --python .venv/Scripts/python.exe \"huggingface_hub[cli]\"" },
          { "label": "*nix",    "cmd": "uv pip install --python .venv/bin/python \"huggingface_hub[cli]\"" }
        ],
        "docs": "https://huggingface.co/docs/huggingface_hub/guides/cli"
      }
    },
    {
      "type": "install_uv_package",
      "name": "安装 modelscope（ZipEnhancer 必需）",
      "package": "modelscope",
      "import_as": ["modelscope"],
      "venv_dir": ".venv",
      "spec": "modelscope",
      "install_hint": {
        "intro": "modelscope 安装失败。可手动执行：",
        "commands": [
          { "label": "Windows", "cmd": "uv pip install --python .venv/Scripts/python.exe modelscope" },
          { "label": "*nix",    "cmd": "uv pip install --python .venv/bin/python modelscope" }
        ],
        "docs": "https://www.modelscope.cn/docs"
      }
    },
    {
      "type": "install_uv_package",
      "name": "安装 sherpa-onnx",
      "package": "sherpa-onnx",
      "import_as": ["sherpa_onnx"],
      "venv_dir": ".venv",
      "spec": "sherpa-onnx",
      "install_hint": {
        "intro": "sherpa-onnx 安装失败。可手动执行：",
        "commands": [
          { "label": "Windows",      "cmd": "uv pip install --python .venv/Scripts/python.exe sherpa-onnx" },
          { "label": "*nix",         "cmd": "uv pip install --python .venv/bin/python sherpa-onnx" },
          { "label": "k2-fsa 镜像", "cmd": "uv pip install --python .venv/Scripts/python.exe sherpa-onnx -f https://k2-fsa.github.io/sherpa/onnx/cpu.html" }
        ],
        "docs": "https://k2-fsa.github.io/sherpa/onnx/install/index.html"
      }
    },
    {
      "type": "download_models",
      "name": "下载模型到 ./models",
      "venv_dir": ".venv",
      "models": [
        {
          "sources": [
            { "source": "hf",         "repo": "openbmb/VoxCPM2", "label": "HuggingFace (海外/香港)" },
            { "source": "modelscope", "repo": "OpenBMB/VoxCPM2", "label": "ModelScope (国内)" }
          ],
          "source_prompt": "VoxCPM2 选源? Y=HuggingFace / N=ModelScope [Y/N]: ",
          "local_dir": "models/VoxCPM2",
          "skip_if_exists": true,
          "note": "VoxCPM2 主模型"
        },
        {
          "source": "modelscope",
          "repo": "iic/speech_zipenhancer_ans_multiloss_16k_base",
          "local_dir": "models/ZipEnhancer",
          "skip_if_exists": true,
          "note": "ZipEnhancer 降噪（仅 ModelScope）"
        },
        {
          "source": "url",
          "url": "https://github.com/k2-fsa/sherpa-onnx/releases/download/tts-models/sherpa-onnx-zipvoice-distill-zh-en-emilia.tar.bz2",
          "local_dir": "models/sherpa-zipvoice",
          "skip_if_exists": true,
          "note": "sherpa-onnx ZipVoice 克隆模型（蒸馏 fp32，中英双语，包内已含 vocoder，自动解压）"
        }
      ],
      "install_hint": {
        "intro": "模型下载失败。可手动重试：",
        "commands": [
          { "label": "VoxCPM2 (HF)",         "cmd": ".venv\\Scripts\\hf.exe download openbmb/VoxCPM2 --local-dir models\\VoxCPM2" },
          { "label": "VoxCPM2 (ModelScope)", "cmd": ".venv\\Scripts\\modelscope.exe download --model OpenBMB/VoxCPM2 --local_dir models\\VoxCPM2" },
          { "label": "ZipEnhancer",          "cmd": ".venv\\Scripts\\modelscope.exe download --model iic/speech_zipenhancer_ans_multiloss_16k_base --local_dir models\\ZipEnhancer" },
          { "label": "ZipVoice tar",         "cmd": "curl -L -o models\\sherpa-zipvoice\\sherpa-onnx-zipvoice-distill-zh-en-emilia.tar.bz2 https://github.com/k2-fsa/sherpa-onnx/releases/download/tts-models/sherpa-onnx-zipvoice-distill-zh-en-emilia.tar.bz2" }
        ]
      }
    },
    {
      "type": "run_venv_cli",
      "name": "生成测试音频 out.wav",
      "venv_dir": ".venv",
      "cli": "voxcpm",
      "args": [
        "design",
        "--text", "Hello from VoxCPM2!",
        "--control", "warm female voice, calm and friendly",
        "--output", "out.wav",
        "--model-path", "models/VoxCPM2",
        "--zipenhancer-path", "models/ZipEnhancer",
        "--local-files-only"
      ],
      "skip_if_missing": true,
      "output_file": "out.wav",
      "install_hint": {
        "intro": "voxcpm CLI 执行失败。可手动尝试：",
        "commands": [
          { "label": "Windows",  "cmd": ".venv\\Scripts\\voxcpm.exe design --text \"Hello from VoxCPM2!\" --control \"warm female voice\" --output out.wav --model-path models\\VoxCPM2 --zipenhancer-path models\\ZipEnhancer --local-files-only" },
          { "label": "*nix",     "cmd": ".venv/bin/voxcpm design --text \"Hello from VoxCPM2!\" --control \"warm female voice\" --output out.wav --model-path models/VoxCPM2 --zipenhancer-path models/ZipEnhancer --local-files-only" },
          { "label": "禁用降噪", "cmd": ".venv\\Scripts\\voxcpm.exe design --text \"Hello from VoxCPM2!\" --output out.wav --model-path models\\VoxCPM2 --no-denoiser --local-files-only" }
        ]
      }
    }
  ]
}
